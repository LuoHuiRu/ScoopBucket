    "url": "https://github.com/kovidgoyal/calibre/releases/download/v9.7.0/calibre-portable-installer-9.7.0.exe",
    "hash": "20052f875f97e76d839a3eed0368954d0b61ca699b62882f6dbb0cf0c4e8afb9",
    "installer": {
        "script": [
            "Start-Process \"$dir\\calibre-portable-installer-$version.exe\" @(\"$dir\") -Wait",
            "Move-Item \"$dir\\Calibre Portable\\**\" \"$dir\"",
            "Remove-Item \"$dir\\Calibre Portable\""
        ]
    },
    "bin": [
        [
            "calibre-portable.exe",
            "calibre"
        ],
        [
            "Calibre\\calibre-debug.exe",
            "calibre-debug"
        ]
    ],
    "shortcuts": [
        [
            "calibre-portable.exe",
            "Calibre"
        ]
    ],
    "persist": [
        "Calibre Library",
        "Calibre Settings"
    ],
    "checkver": {
        "github": "https://github.com/kovidgoyal/calibre"
    },
    "autoupdate": {
        "url": "https://github.com/kovidgoyal/calibre/releases/download/v$version/calibre-portable-installer-$version.exe"
    }
}
